# Ignore node_modules in both frontend and backend
frontend/Client/node_modules/
backend/node_modules/

# Ignore environment variables / secrets
backend/.env
backend/.env.local
frontend/Client/.env
frontend/Client/.env.local

# Ignore build/dist folders (created when compiling frontend)
frontend/Client/dist/
frontend/Client/build/

# Ignore OS specific files
.DS_Store
Thumbs.db

frontend/Client/.DS_Store
frontend/Client/Thumbs.db
frontend/Client/.vscode/
frontend/Client/.angular/